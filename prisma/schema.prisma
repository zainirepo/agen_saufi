// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CEO
  ADMIN
}

enum PaymentStatus {
  BELUM
  DP
  LUNAS
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
}

model Order {
  id            String        @id @default(cuid())
  namaPemesan   String
  noHp          String
  statusBayar   PaymentStatus @default(BELUM)
  fileUrl       String?
  fileName      String?
  fileSize      Int?
  catatan       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
